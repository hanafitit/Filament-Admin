APP_NAME="Portfolio Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
DIAGNOSTICS_ENABLED=false
DIAGNOSTICS_LOG_CHANNEL=performance
DIAGNOSTICS_SLOW_QUERY_MS=250
DIAGNOSTICS_LOG_ALL_QUERIES=false
DIAGNOSTICS_LOG_DAYS=7

APP_DB_MODE=local
DB_CONNECTION=sqlite
DB_LOCAL_CONNECTION=sqlite
DB_REMOTE_CONNECTION=pgsql_remote
DB_FOREIGN_KEYS=true
SQLITE_DB_URL=
SQLITE_DB_DATABASE=database/database.sqlite

LOCAL_DB_URL=
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=5432
LOCAL_DB_DATABASE=freelance_crm
LOCAL_DB_USERNAME=
LOCAL_DB_PASSWORD=
LOCAL_DB_CHARSET=utf8
LOCAL_DB_SCHEMA=public
LOCAL_DB_SSLMODE=prefer

REMOTE_DB_URL=
REMOTE_DB_HOST=
REMOTE_DB_PORT=5432
REMOTE_DB_DATABASE=
REMOTE_DB_USERNAME=
REMOTE_DB_PASSWORD=
REMOTE_DB_CHARSET=utf8
REMOTE_DB_SCHEMA=public
REMOTE_DB_SSLMODE=require

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

BACKUP_ARCHIVE_PASSWORD=

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
